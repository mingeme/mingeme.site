---
import type { CollectionEntry } from 'astro:content';

const dateFormatter = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});

type Props = {
  entry: CollectionEntry<'blog'>;
  index?: number;
};

const { entry } = Astro.props;
const href = `/${entry.collection}/${entry.id.replace(/\.(md|mdx)$/, '')}`;
const date = dateFormatter.format(entry.data.date).replaceAll('/', '.');
const tags = entry.data.tags?.length ? entry.data.tags.map((tag) => `#${tag}`).join(' ') : '';
---

<a
  href={href}
  class="grid gap-x-5 gap-y-0.5 py-2 text-muted no-underline transition-colors duration-200 hover:text-ink sm:grid-cols-[7.25rem_minmax(0,1fr)]"
>
  <span class="font-meta whitespace-nowrap pt-0 text-xs leading-6 text-faint sm:pt-1">
    {date}
  </span>
  <span class="min-w-0">
    <span class="block text-[clamp(1.05rem,1.8vw,1.22rem)] font-medium leading-snug tracking-[-0.025em] text-ink">
      {entry.data.title}
    </span>
    {tags && <span class="font-meta mt-0.5 block text-xs leading-6 text-faint">{tags}</span>}
  </span>
</a>
