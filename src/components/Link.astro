---
import { cn } from '@/lib/utils';

type Props = {
  href: string;
  external?: boolean;
  underline?: boolean;
};

const { href, external, underline = true, ...rest } = Astro.props;
---

<a
  href={href}
  target={external ? '_blank' : '_self'}
  class={cn(
    'inline-block text-current transition-colors duration-200 hover:text-[var(--accent)]',
    underline && 'underline decoration-[var(--faint)] underline-offset-2 hover:decoration-[var(--accent)]',
  )}
  {...rest}
>
  <slot />
</a>
