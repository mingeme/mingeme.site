---
import Container from '@/components/Container.astro';
---

<header class="site-header">
  <Container>
    <div class="flex flex-wrap gap-x-8 gap-y-3 justify-between items-center border-b py-5 text-sm font-meta" style="border-color: var(--line);">
      <a
        href="/"
        class="font-sans text-base font-bold leading-none tracking-[0.08em] text-[var(--text)] no-underline transition-colors duration-200 hover:text-[var(--accent)]"
        aria-label="HENMIHU"
      >
        HENMIHU
      </a>

      <nav class="flex flex-wrap gap-x-4 gap-y-2 items-center">
        <a class="nav-link" href="/blog">/手记</a>
        <a class="nav-link" href="/misc">/边角料</a>
        <a class="nav-link" href="/tags">/标本</a>
        <a class="nav-link" href="/about">/此处</a>
      </nav>
    </div>
  </Container>
</header>
