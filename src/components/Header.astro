---
import Container from '@/components/Container.astro';
import { SITE } from '@/consts';
---

<header class="site-header">
  <Container>
    <div class="flex flex-wrap gap-x-8 gap-y-3 justify-between items-center text-sm font-meta">
      <a href="/" class="wordmark" aria-label={SITE.NAME}>
        HENMIHU
      </a>

      <nav class="flex flex-wrap gap-x-3 gap-y-2 items-center">
        <a class="nav-link" href="/blog">/手记</a>
        <a class="nav-link" href="/misc">/边角料</a>
        <a class="nav-link" href="/tags">/标本</a>
        <a class="nav-link" href="/about">/此处</a>
        <span class="hidden text-faint sm:inline">|</span>
        <button id="light-theme-button" class="theme-button" aria-label="浅色模式" title="浅色模式">light</button>
        <button id="dark-theme-button" class="theme-button" aria-label="深色模式" title="深色模式">dark</button>
        <button id="system-theme-button" class="theme-button" aria-label="跟随系统" title="跟随系统">auto</button>
      </nav>
    </div>
  </Container>
</header>
